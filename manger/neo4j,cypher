// 关联到现有的试卷 (假设试卷 ID 为 8888，如果不存在则创建占位符)
MERGE (p:Paper {id: 8888})
ON CREATE SET p.name = "Java与数据结构期中考试", p.total_score = 100

// 关联到现有的考试定义
MERGE (e:Exam {id: 8888})
ON CREATE SET e.title = "2025秋季期中考试"
