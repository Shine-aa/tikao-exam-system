// 创建学生 2 的考试记录
CREATE (se_case:StudentExam {
    id: 888802,
    score: 60, // 总分 60/100 (6题对, 4题错)
    status: 'COMPLETED',
    createTime: datetime('2025-11-27T14:30:00')
})

// 将学生 2 关联到此考试
WITH se_case, e
MATCH (u:User {id: 2})
CREATE (u)-[:TAKES]->(se_case)
CREATE (se_case)-[:FOR_EXAM]->(e)


